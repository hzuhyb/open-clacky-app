{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "open-clacky-app",
  "version": "0.1.0",
  "identifier": "com.robin.open-clacky-app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenClacky",
        "width": 900,
        "height": 600,
        "resizable": true,
        "center": true,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:7070; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; frame-src http://127.0.0.1:7070"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
